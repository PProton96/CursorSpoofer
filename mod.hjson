#the mod name as displayed in-game
displayName: "Cursor Spoofer"

#the internal name of your mod
name: "cursor-spoofer"

#your name
author: "PProton"

#the fully qualified main class of the mod
main: "pproton.CursorSpooferMod"

#the mod description as seen in the mod dialog
description: "Makes server think your cursor is directly on your unit."

#the mod version
version: 1.0

#the minimum game build required to run this mod
minGameVersion: 154

#this is a java mod
java: true

#whether the mod should be hidden froms servers
hidden:true