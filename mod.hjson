#the mod name as displayed in-game
displayName: "Cursor Spoofer"

#the internal name of your mod
name: "cursor-spoofer"

#your name
author: "PProton"

#the fully qualified main class of the mod
main: "pproton.CursorSpooferMod"

#the mod description as seen in the mod dialog
description: "Hides your cursor from cheaters, now it will appear to always be on your unit, unless you try to shoot."

#the mod version
version: 1.0

#the minimum game build required to run this mod
minGameVersion: 154

#this is a java mod
java: true

#whether the mod should be hidden from servers
hidden: true